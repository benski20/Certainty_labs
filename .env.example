# API server: copy this file to .env in the project root and set values.
# .env is loaded at startup (see api/main.py). Do not commit .env.

# Optional: Supabase for persistent API key storage.
# If unset, keys are stored in certainty_workspace/api_keys.json (local only).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
